{
  "name": "ask-question-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.17.0",
    "npm": ">=10.9.2"
  },
  "description": "Frontend портала вопросов и ответов",
  "author": "Григорий Алексанян",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prettier:check": "prettier ./src --check",
    "eslint:check": "eslint ./src/**/*.{vue,ts}",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "stylelint:check": "stylelint ./src/**/*.{vue,scss,css}",
    "lint": "npm run prettier:check && npm run eslint:check && npm run stylelint:check",
    "fsd:check": "steiger ./src",
    "husky:prepare": "husky || true",
    "commit": "better-commits"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "docx": "^9.7.1",
    "dompurify": "^3.4.5",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.7",
    "vuedraggable": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@feature-sliced/steiger-plugin": "^0.5.8",
    "@types/file-saver": "^2.0.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "better-commits": "^1.23.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-import-resolver-vite": "^2.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "steiger": "^0.5.12",
    "stylelint": "^17.12.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.vue": [
      "prettier --write",
      "eslint --fix",
      "stylelint --fix"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write",
      "stylelint --fix"
    ]
  }
}
