{
  "name": "ask-question-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.17.0",
    "npm": ">=10.9.2"
  },
  "description": "Frontend портала вопросов и ответов",
  "author": "Григорий Алексанян",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prettier:check": "prettier ./src --check",
    "eslint:check": "eslint ./src/**/*.{vue,js}",
    "stylelint:check": "stylelint ./src/**/*.{vue,scss,css}",
    "lint": "npm run prettier:check && npm run eslint:check && npm run stylelint:check",
    "fsd:check": "steiger ./src",
    "husky:prepare": "husky || true",
    "commit": "git-cz"
  },
  "dependencies": {
    "@vee-validate/rules": "^4.15.1",
    "axios": "^1.16.1",
    "dompurify": "^3.4.5",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "vue-responsive-video-background-player": "^2.4.1",
    "vue-router": "^5.0.7",
    "vuedraggable": "^4.1.0",
    "vuetify": "^4.0.7",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@feature-sliced/steiger-plugin": "^0.5.8",
    "@mdi/font": "^7.4.47",
    "@vitejs/plugin-vue": "^6.0.7",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vuetify": "^2.7.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "steiger": "^0.5.12",
    "stylelint": "^17.12.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "vite": "^8.0.14",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "./configs/git/commitizen.cjs"
    }
  },
  "lint-staged": {
    "src/**/*.js": [
      "prettier --check",
      "eslint"
    ],
    "src/**/*.vue": [
      "prettier --check",
      "eslint",
      "stylelint"
    ],
    "src/**/*.{css,scss}": [
      "prettier --check",
      "stylelint"
    ]
  }
}
